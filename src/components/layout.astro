---
const { title } = Astro.props;
const yellow = "#F9D71C";
---
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#0b0b0b] text-white">
    <header class="p-6 border-b border-zinc-800 sticky top-0 bg-[#0b0b0b]/90 backdrop-blur z-50 flex justify-between items-center">
        <div class="text-2xl font-black italic uppercase tracking-tighter" style={`color: ${yellow}`}>⚡ ORIGINES</div>
        <nav class="hidden md:flex gap-6 text-xs font-bold uppercase text-zinc-400">
            <a href="/" class="hover:text-white">Catalogue</a>
            <a href="#" class="hover:text-white">Favoris</a>
            <a href="#" class="hover:text-white">Connexion</a>
        </nav>
    </header>
    <slot />
</body>
</html>