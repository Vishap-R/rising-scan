---
import Layout from '../layouts/Layout.astro';
import mangasData from '../data/mangas.json';

// Sécurité : on s'assure que mangasData est bien un tableau pour éviter le crash du .map()
const mangas = Array.isArray(mangasData) ? mangasData : [];

const yellow = "#F9D71C";
---

<Layout title="Rising Scan - Accueil">
  <main class="min-h-screen bg-[#0b0b0b] text-white p-6">
    
    <div class="max-w-6xl mx-auto mt-10">
      
      <h2 class="text-xl font-bold mb-8 flex items-center gap-4 uppercase italic tracking-widest">
        <span class="w-12 h-1 bg-yellow-400"></span> 
        Dernières Sorties
      </h2>

      {mangas.length === 0 ? (
        /* État vide si aucun manga n'est publié */
        <div class="flex flex-col items-center justify-center py-32 border-2 border-dashed border-zinc-800 rounded-3xl bg-zinc-900/20">
          <div class="text-4xl mb-4 opacity-20">⚡</div>
          <p class="text-zinc-500 italic text-sm">Aucune œuvre pour le moment...</p>
          <p class="text-[10px] text-zinc-700 mt-2 uppercase tracking-widest">Le catalogue est en cours de chargement</p>
        </div>
      ) : (
        /* Grille des Mangas */
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8">
          {mangas.map((manga) => (
            <a href={`/manga/${manga.id}`} class="group flex flex-col gap-3">
              <div class="relative aspect-[3/4] overflow-hidden rounded-xl border-2 border-zinc-800 group-hover:border-yellow-400 transition-all duration-300 shadow-[0_0_20px_rgba(0,0,0,0.5)]">
                <img 
                  src={manga.cover || 'https://via.placeholder.com/300x400?text=No+Cover'} 
                  alt={manga.title}
                  loading="lazy" 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                
                <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                   <div class="flex flex-col">
                     <span class="text-[10px] text-yellow-400 font-black uppercase tracking-tighter">Lire le chapitre 1</span>
                     <span class="text-white text-xs font-bold uppercase truncate">{manga.title}</span>
                   </div>
                </div>

                <div class="absolute top-2 left-2 bg-yellow-400 text-black text-[9px] font-black px-2 py-0.5 rounded uppercase italic">
                  New
                </div>
              </div>

              <div class="space-y-1">
                <h3 class="font-black text-sm truncate uppercase tracking-tight group-hover:text-yellow-400 transition-colors">
                  {manga.title}
                </h3>
                <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest">
                  Chapitre {manga.chapters ? manga.chapters.length : '0'}
                </p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <footer class="max-w-6xl mx-auto mt-32 pb-10 border-t border-zinc-900 pt-10 text-center">
        <p class="text-zinc-600 text-[10px] uppercase tracking-[0.3em]">
          Powered by <span class="text-zinc-400">Rising Scan Engine</span>
        </p>
    </footer>

  </main>
</Layout>

<style>
  /* Animation d'entrée douce pour les cartes */
  .group {
    animation: fadeIn 0.5s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
