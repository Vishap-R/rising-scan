---
import Layout from '../layouts/Layout.astro';
import mangas from '../data/mangas.json';
const yellow = "#F9D71C";
---

<Layout title="Rising Scan - Accueil">
  <main class="max-w-7xl mx-auto p-6 space-y-12">
    
    <section>
      <div class="flex items-center gap-3 mb-8 border-l-4 pl-4" style={`border-color: ${yellow}`}>
        <h2 class="text-2xl font-black uppercase tracking-tighter italic">Dernières <span style={`color: ${yellow}`}>Sorties</span></h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
        {mangas.map(manga => (
          <a href={`/manga/${manga.id}`} class="group relative flex flex-col gap-3">
            
            {manga.status && manga.status !== "NONE" && (
              <div class="absolute top-3 left-3 z-20 px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-tighter shadow-lg shadow-black/50" 
                   style={`background-color: ${yellow}; color: black;`}>
                {manga.status}
              </div>
            )}

            <div class="aspect-[3/4] rounded-2xl overflow-hidden border border-zinc-800 group-hover:border-[#F9D71C] transition-all duration-300 relative bg-zinc-900">
              <img 
                src={manga.cover} 
                loading="lazy" 
                alt={manga.title}
                class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500 opacity-90 group-hover:opacity-100"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>

            <div class="space-y-1">
              <h4 class="text-sm font-bold truncate group-hover:text-[#F9D71C] transition-colors">{manga.title}</h4>
              <div class="flex justify-between items-center">
                <span class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest">
                  Chapitre {manga.chapters.length > 0 ? manga.chapters[manga.chapters.length - 1].number : '0'}
                </span>
                <span class="text-[9px] text-zinc-600">ScanTrad</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

</Layout>
