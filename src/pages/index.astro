---
import Layout from '../layouts/Layout.astro';
import mangasData from '../data/mangas.json';

// LOGIQUE D'EXTRACTION ULTRA-ROBUSTE
let mangas = [];

// 1. On récupère les données (gestion du .default d'Astro)
const rawData = mangasData?.default || mangasData;

// 2. On s'assure que c'est un tableau
if (Array.isArray(rawData)) {
  mangas = rawData;
} else if (rawData && typeof rawData === 'object' && rawData.id) {
  // Si le JSON contient un seul manga (objet direct), on le met dans un tableau
  mangas = [rawData];
}

const yellow = "#F9D71C";
---

<Layout title="Rising Scan - Accueil">
  <main class="min-h-screen bg-[#0b0b0b] text-white p-6">
    
    <div class="max-w-6xl mx-auto mt-10">
      
      <h2 class="text-xl font-bold mb-10 flex items-center gap-4 uppercase italic tracking-widest">
        <span class="w-12 h-1 bg-yellow-400"></span> 
        Dernières Sorties
      </h2>

      {mangas.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-32 border-2 border-dashed border-zinc-800 rounded-3xl bg-zinc-900/20">
          <div class="text-5xl mb-4 animate-pulse text-yellow-400">⚡</div>
          <p class="text-zinc-500 italic text-sm">Aucune donnée trouvée dans le JSON...</p>
        </div>
      ) : (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-x-6 gap-y-10">
          {mangas.map((manga) => (
            <a href={`/manga/${manga.id}`} class="group flex flex-col gap-3">
              
              <div class="relative aspect-[3/4] overflow-hidden rounded-xl border-2 border-zinc-800 group-hover:border-yellow-400 transition-all duration-500 shadow-2xl bg-zinc-900">
                <img 
                  src={manga.cover} 
                  alt={manga.title}
                  loading="lazy" 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  onerror="this.src='https://via.placeholder.com/300x400?text=Image+Introuvable'"
                />
                
                <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                   <span class="text-[10px] text-yellow-400 font-black uppercase tracking-widest italic">Lire le chapitre</span>
                </div>
              </div>

              <div class="space-y-1 px-1">
                <h3 class="font-black text-sm truncate uppercase tracking-tight group-hover:text-yellow-400 transition-colors">
                  {manga.title}
                </h3>
                <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest">
                  {manga.chapters ? manga.chapters.length : '0'} Chapitre(s)
                </p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <footer class="max-w-6xl mx-auto mt-32 pb-10 border-t border-zinc-900 pt-10 text-center">
        <p class="text-zinc-600 text-[9px] uppercase tracking-[0.5em]">
          Rising Scan — Catalogue Officiel
        </p>
    </footer>

  </main>
</Layout>

<style>
  .group {
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
