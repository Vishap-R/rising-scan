---
import Layout from '../layouts/Layout.astro';
import mangasData from '../data/mangas.json';

const currentMangas = Array.isArray(mangasData) ? mangasData : (mangasData?.default || []);
const yellow = "#F9D71C";
---

<Layout title="Admin Space - Rising Scan">
  <main class="min-h-screen bg-[#0b0b0b] text-white p-6 md:p-12">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl font-black uppercase italic mb-8">Admin <span style={`color: ${yellow}`}>Turbo</span></h1>

      <div id="drop-zone" class="border-2 border-dashed border-zinc-800 rounded-3xl p-12 text-center hover:border-yellow-400 transition-all cursor-pointer bg-zinc-900/20 group">
        <input type="file" id="zip-input" accept=".zip" class="hidden" />
        <p id="drop-text" class="text-sm font-bold uppercase tracking-widest text-zinc-400 group-hover:text-white"> Glissez votre fichier <span class="text-yellow-400">.ZIP</span> ici </p>
      </div>

      <div id="config-panel" class="mt-8 bg-zinc-900/50 border border-zinc-800 rounded-2xl p-6 hidden space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <select id="mangaId" class="bg-black border border-zinc-800 rounded-xl p-3 text-sm outline-none">
            {currentMangas.map((m: any) => <option value={m.id}>{m.title}</option>)}
          </select>
          <input type="number" id="chNumber" placeholder="N° Chapitre" class="bg-black border border-zinc-800 rounded-xl p-3 text-sm outline-none" />
        </div>

        <div id="status-bar" class="hidden space-y-2">
            <div class="flex justify-between text-[10px] font-bold uppercase text-yellow-400">
                <span id="st-text">Prêt</span>
                <span id="st-perc">0%</span>
            </div>
            <div class="h-1 bg-zinc-800 rounded-full overflow-hidden"><div id="prog-bar" class="h-full bg-yellow-400 w-0 transition-all"></div></div>
        </div>

        <button id="start-upload" class="w-full py-4 bg-yellow-400 text-black font-black uppercase text-[10px] rounded-xl shadow-lg">Extraire & Upload</button>
      </div>
    </div>
  </main>
</Layout>

<script>
  import JSZip from 'jszip';

  const zipInput = document.getElementById('zip-input') as HTMLInputElement;
  const dropZone = document.getElementById('drop-zone');
  const configPanel = document.getElementById('config-panel');
  let selectedFile: File | null = null;

  // Remplace par tes infos Cloudinary
  const CLOUD_NAME = "TON_CLOUD_NAME"; 
  const UPLOAD_PRESET = "TON_PRESET_UNSIGNED"; 

  dropZone?.addEventListener('click', () => zipInput.click());
  zipInput.addEventListener('change', (e: any) => handleFile(e.target.files[0]));
  dropZone?.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.style.borderColor = "#F9D71C"; });
  dropZone?.addEventListener('drop', (e: any) => { e.preventDefault(); handleFile(e.dataTransfer.files[0]); });

  function handleFile(file: File) {
    if (file?.name.endsWith('.zip')) {
      selectedFile = file;
      configPanel?.classList.remove('hidden');
      document.getElementById('drop-text')!.innerText = `Fichier prêt : ${file.name}`;
    }
  }

  document.getElementById('start-upload')?.addEventListener('click', async () => {
    if (!selectedFile) return;
    const mId = (document.getElementById('mangaId') as HTMLSelectElement).value;
    const chNum = (document.getElementById('chNumber') as HTMLInputElement).value;
    
    const bar = document.getElementById('prog-bar');
    const stText = document.getElementById('st-text');
    document.getElementById('status-bar')?.classList.remove('hidden');

    try {
      const zip = new JSZip();
      const zipData = await zip.loadAsync(selectedFile);
      const images = Object.keys(zipData.files).filter(f => f.match(/\.(jpg|jpeg|png|webp)$/i)).sort();
      const urls = [];

      for (let i = 0; i < images.length; i++) {
        const blob = await zipData.files[images[i]].async("blob");
        const fd = new FormData();
        fd.append('file', blob);
        fd.append('upload_preset', UPLOAD_PRESET);

        stText!.innerText = `Upload ${i+1}/${images.length}`;
        const res = await fetch(`https://api.cloudinary.com/v1_1/${CLOUD_NAME}/image/upload`, { method: 'POST', body: fd });
        const data = await res.json();
        
        if (data.secure_url) urls.push(data.secure_url);
        bar!.style.width = `${Math.round(((i+1)/images.length)*100)}%`;
      }

      // Envoi à l'API GitHub
      await fetch('/api/update-mangas', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: "ADD_CHAPTER", mangaId: mId, chapter: { number: chNum, pages: urls, date: new Date().toLocaleDateString() } })
      });

      alert("Succès !");
      window.location.reload();
    } catch (err) { alert("Erreur : " + err); }
  });
</script>
