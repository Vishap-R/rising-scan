---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admin Space - Rising Scan">
  <main id="adminContent" class="hidden min-h-screen bg-[#0b0b0b] text-white p-4 font-sans">
    
    <header class="flex justify-between items-center border-b-4 border-yellow-400 pb-4 mb-8">
      <h1 class="text-3xl font-black text-yellow-400 uppercase tracking-tighter italic">
        ⚡ Admin Space <span class="text-white text-sm font-normal not-italic">v2.3</span>
      </h1>
      <div class="space-x-2">
        <button id="exportBtn" class="bg-zinc-800 hover:bg-zinc-700 px-3 py-1 rounded text-[10px] font-bold border border-zinc-700 transition uppercase tracking-widest text-yellow-400">Export JSON</button>
        <button id="importBtn" class="bg-zinc-800 hover:bg-zinc-700 px-3 py-1 rounded text-[10px] font-bold border border-zinc-700 transition uppercase tracking-widest">Import JSON</button>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <section class="lg:col-span-1 space-y-6">
        <div class="bg-zinc-900 p-6 rounded-2xl border border-zinc-800 shadow-2xl">
          <h2 class="text-xl font-black mb-6 flex items-center gap-2 uppercase italic text-yellow-400">
            <span class="bg-yellow-400 text-black px-2 py-0.5 rounded-md not-italic font-black">1</span> Nouveau Manga
          </h2>
          
          <div class="space-y-4">
            <input type="text" id="mangaTitle" placeholder="Titre (ex: Solo Leveling)" class="w-full bg-black border border-zinc-800 p-3 rounded-xl focus:border-yellow-400 outline-none text-white transition" />
            <input type="text" id="mangaId" placeholder="ID (ex: solo-leveling)" class="w-full bg-black border border-zinc-800 p-3 rounded-xl focus:border-yellow-400 outline-none text-zinc-400 transition" />

            <div class="border-2 border-dashed border-zinc-800 p-6 rounded-2xl text-center hover:border-yellow-400 cursor-pointer transition bg-black group" id="dropZoneCover">
              <p class="text-zinc-500 text-xs font-bold uppercase group-hover:text-yellow-400" id="coverStatus">🖼️ Sélectionner la Cover</p>
              <input type="file" id="fileCover" accept="image/*" class="hidden" />
            </div>
            
            <div class="border-2 border-dashed border-zinc-800 p-6 rounded-2xl text-center hover:border-yellow-400 cursor-pointer transition bg-black group" id="dropZoneZip">
              <p class="text-zinc-500 text-xs font-bold uppercase group-hover:text-yellow-400" id="zipStatus">📁 Glisser le ZIP (Chap. 1)</p>
              <input type="file" id="fileZip" accept=".zip" class="hidden" />
            </div>

            <button id="addMangaBtn" class="w-full bg-yellow-400 hover:bg-yellow-300 text-black font-black py-4 rounded-xl uppercase transition shadow-[0_0_20px_rgba(234,179,8,0.2)]">
              Ajouter à la file
            </button>
          </div>
        </div>
      </section>

      <section class="lg:col-span-2 space-y-6">
        <div class="flex justify-between items-center">
          <h2 class="text-2xl font-black italic uppercase tracking-tighter">File d'attente <span id="queueCount" class="text-yellow-400 ml-2">0</span></h2>
          <button id="publishBtn" class="bg-yellow-400 hover:bg-yellow-300 text-black font-black px-10 py-4 rounded-full shadow-xl transition-all flex items-center gap-2 uppercase italic">
             🚀 Lancer la Publication
          </button>
        </div>
        <div id="mangaList" class="grid grid-cols-1 gap-4"></div>
      </section>
    </div>
  </main>
</Layout>

<script>
  import JSZip from 'jszip';

  // --- SÉCURITÉ ---
  const pass = prompt("Code d'accès :");
  if (pass === "TON_MOT_DE_PASSE") {
      document.getElementById('adminContent').classList.remove('hidden');
  } else {
      window.location.href = "/";
  }

  let db = JSON.parse(localStorage.getItem('rising_scan_db')) || [];
  let currentZipPages = [];
  let currentCoverBlob = null;
  const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

  // --- SELECTION FICHIERS ---
  document.getElementById('dropZoneCover').onclick = () => document.getElementById('fileCover').click();
  document.getElementById('fileCover').onchange = (e) => {
    currentCoverBlob = e.target.files[0];
    if(currentCoverBlob) document.getElementById('coverStatus').innerText = "✅ " + currentCoverBlob.name;
  };

  document.getElementById('dropZoneZip').onclick = () => document.getElementById('fileZip').click();
  document.getElementById('fileZip').onchange = async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    document.getElementById('zipStatus').innerText = "⏳ Lecture...";
    const zip = new JSZip();
    const contents = await zip.loadAsync(file);
    currentZipPages = [];
    const files = Object.keys(contents.files).filter(f => f.match(/\.(jpg|jpeg|png|webp)$/i)).sort((a,b) => a.localeCompare(b, undefined, {numeric: true}));
    for (let f of files) {
        const b = await contents.files[f].async("blob");
        currentZipPages.push({ name: f, blob: b });
    }
    document.getElementById('zipStatus').innerText = `✅ ${currentZipPages.length} Pages`;
  };

  // --- SOLUTION 2 : UPLOAD VIA PUBLIC_ID (FORCE LES DOSSIERS) ---
  async function uploadToCloud(fileBlob, folderPath, fileName) {
    const formData = new FormData();
    formData.append('file', fileBlob);
    formData.append('upload_preset', 'ml_default');
    
    // On combine le dossier et le nom du fichier pour forcer Cloudinary
    // On nettoie le nom pour éviter les caractères interdits
    const cleanFileName = fileName.replace(/[^a-z0-9]/gi, '_').toLowerCase();
    formData.append('public_id', `${folderPath}/${cleanFileName}_${Math.random().toString(36).substring(7)}`);

    const res = await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/image/upload`, {
      method: 'POST',
      body: formData
    });
    
    if(!res.ok) {
        const err = await res.json();
        throw new Error(err.error.message);
    }
    return await res.json();
  }

  // --- GESTION LOCALE ---
  document.getElementById('addMangaBtn').onclick = () => {
    const title = document.getElementById('mangaTitle').value;
    const id = document.getElementById('mangaId').value;
    if(!title || !id || currentZipPages.length === 0 || !currentCoverBlob) return alert("Champs manquants");

    db.push({
      id, title, status: "Ongoing",
      tempCover: currentCoverBlob,
      chapters: [{ number: "1", title: "Chapitre 1", date: new Date().toLocaleDateString(), pages: currentZipPages }]
    });

    save();
    // Reset
    currentZipPages = []; currentCoverBlob = null;
    document.getElementById('mangaTitle').value = ""; document.getElementById('mangaId').value = "";
    document.getElementById('coverStatus').innerText = "🖼️ Sélectionner la Cover";
    document.getElementById('zipStatus').innerText = "📁 Glisser le ZIP (Chap. 1)";
  };

  // --- PUBLICATION FINALE ---
  document.getElementById('publishBtn').onclick = async () => {
    const btn = document.getElementById('publishBtn');
    if (db.length === 0) return alert("File d'attente vide !");
    btn.disabled = true;

    try {
      for (let manga of db) {
        // 1. Upload Cover
        btn.innerText = "⏳ ENVOI COVER...";
        const cData = await uploadToCloud(manga.tempCover, `rising-scan/${manga.id}/assets`, 'cover');
        manga.cover = cData.secure_url;
        delete manga.tempCover;

        // 2. Upload Pages du Chapitre
        const finalUrls = [];
        for (let i = 0; i < manga.chapters[0].pages.length; i++) {
            btn.innerText = `⏳ PAGE ${i+1}/${manga.chapters[0].pages.length}`;
            const pData = await uploadToCloud(manga.chapters[0].pages[i].blob, `rising-scan/${manga.id}/ch1`, `page_${i+1}`);
            finalUrls.push(pData.secure_url);
        }
        manga.chapters[0].pages = finalUrls;

        // 3. GitHub
        btn.innerText = "☁️ MISE À JOUR GITHUB...";
        const res = await fetch('/api/update-mangas', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'json', mangaData: manga })
        });
        if(!res.ok) throw new Error("Erreur lors de la mise à jour GitHub");
      }
      
      alert("🔥 TOUT EST EN LIGNE !");
      db = []; save();
    } catch (e) {
      alert("ERREUR : " + e.message);
    } finally {
      btn.disabled = false;
      btn.innerText = "🚀 Lancer la Publication";
    }
  };

  function save() { localStorage.setItem('rising_scan_db', JSON.stringify(db)); render(); }
  function render() {
    document.getElementById('queueCount').innerText = db.length;
    document.getElementById('mangaList').innerHTML = db.map((m, i) => `
      <div class="bg-zinc-900 border border-zinc-800 p-4 flex justify-between rounded-2xl items-center shadow-lg">
        <div>
            <h3 class="font-black text-yellow-400 italic uppercase">${m.title}</h3>
            <p class="text-[9px] text-zinc-500 font-bold tracking-widest uppercase">ID: ${m.id} | ${m.chapters[0].pages.length} Pages</p>
        </div>
        <button onclick="removeManga(${i})" class="text-[10px] text-zinc-600 uppercase font-black hover:text-red-500 transition">Retirer</button>
      </div>
    `).join('');
  }
  window.removeManga = (i) => { db.splice(i, 1); save(); };

  // Export/Import JSON (Comme demandé pour le LocalStorage)
  document.getElementById('exportBtn').onclick = () => {
    const blob = new Blob([JSON.stringify(db)], {type:'application/json'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `backup_rising_${new Date().getTime()}.json`;
    a.click();
  };

  document.getElementById('importBtn').onclick = () => {
    const input = document.createElement('input');
    input.type = 'file';
    input.onchange = e => {
      const reader = new FileReader();
      reader.onload = () => { db = JSON.parse(reader.result); save(); };
      reader.readAsText(e.target.files[0]);
    };
    input.click();
  };

  render();
</script>
