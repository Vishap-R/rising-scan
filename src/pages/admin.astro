---
import Layout from '../layouts/Layout.astro';
import mangasData from '../data/mangas.json';

const rawData = mangasData?.default || mangasData;
const currentMangas = Array.isArray(rawData) ? rawData : (rawData ? [rawData] : []);
const yellow = "#F9D71C";
---

<Layout title="Admin Space - Rising Scan">
  <div id="admin-gate" class="fixed inset-0 bg-black z-[100] flex items-center justify-center">
    <div class="text-center space-y-4">
      <div class="text-4xl">⚡</div>
      <h2 class="text-xl font-black uppercase italic tracking-tighter text-white">Accès Restreint</h2>
    </div>
  </div>

  <main id="admin-content" class="min-h-screen bg-[#0b0b0b] text-white p-4 md:p-10 opacity-0 transition-opacity">
    <div class="max-w-6xl mx-auto">
      
      <div class="flex flex-col md:flex-row justify-between items-center mb-12 border-b border-zinc-800 pb-6 gap-4">
        <div>
          <h1 class="text-3xl font-black uppercase italic tracking-tighter">Admin <span style={`color: ${yellow}`}>Space</span></h1>
          <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-[0.3em]">Gestion du catalogue & chapitres</p>
        </div>
        <button id="exportData" class="px-4 py-2 bg-zinc-900 border border-zinc-800 rounded-lg text-[10px] font-bold uppercase">📥 Backup JSON</button>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        <div class="lg:col-span-1 space-y-6">
          <div class="flex bg-zinc-900 p-1 rounded-xl border border-zinc-800">
            <button onclick="switchTab('new-manga')" id="btn-new-manga" class="flex-1 py-2 text-[9px] font-black uppercase rounded-lg bg-yellow-400 text-black">Nouveau Manga</button>
            <button onclick="switchTab('new-chapter')" id="btn-new-chapter" class="flex-1 py-2 text-[9px] font-black uppercase rounded-lg text-zinc-500">Nouveau Chapitre</button>
          </div>

          <div id="form-new-manga" class="bg-zinc-900/50 p-6 rounded-2xl border border-zinc-800 shadow-xl">
            <form id="mangaForm" class="space-y-4">
              <input type="hidden" name="action" value="CREATE_MANGA" />
              <div class="space-y-1">
                <label class="text-[9px] uppercase font-bold text-zinc-500">ID Unique (ex: TFSOE)</label>
                <input type="text" name="id" required class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm focus:border-yellow-400 outline-none" />
              </div>
              <div class="space-y-1">
                <label class="text-[9px] uppercase font-bold text-zinc-500">Titre</label>
                <input type="text" name="title" required class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm focus:border-yellow-400 outline-none" />
              </div>
              <div class="space-y-1">
                <label class="text-[9px] uppercase font-bold text-zinc-500">URL Cover</label>
                <input type="url" name="cover" required class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm focus:border-yellow-400 outline-none" />
              </div>
              <button type="submit" class="w-full py-4 font-black uppercase rounded-xl text-black text-[10px] bg-yellow-400 shadow-lg">Publier l'œuvre</button>
            </form>
          </div>

          <div id="form-new-chapter" class="hidden bg-zinc-900/50 p-6 rounded-2xl border border-zinc-800 shadow-xl">
            <form id="chapterForm" class="space-y-4">
              <div class="space-y-1">
                <label class="text-[9px] uppercase font-bold text-zinc-500">Sélectionner le Manga</label>
                <select id="selectManga" name="mangaId" class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm focus:border-yellow-400 outline-none">
                  {currentMangas.map(m => <option value={m.id}>{m.title}</option>)}
                </select>
              </div>
              <div class="flex gap-2">
                <div class="flex-1 space-y-1">
                    <label class="text-[9px] uppercase font-bold text-zinc-500">N° Chapitre</label>
                    <input type="number" name="number" required class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm focus:border-yellow-400 outline-none" />
                </div>
                <div class="flex-1 space-y-1">
                    <label class="text-[9px] uppercase font-bold text-zinc-500">Date</label>
                    <input type="text" name="date" value={new Date().toLocaleDateString()} class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm focus:border-yellow-400 outline-none" />
                </div>
              </div>
              <div class="space-y-1">
                <label class="text-[9px] uppercase font-bold text-zinc-500">Pages (URLs séparées par des virgules)</label>
                <textarea name="pages" rows="5" placeholder="Lien1, Lien2..." required class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm focus:border-yellow-400 outline-none resize-none text-[10px]"></textarea>
              </div>
              <button type="submit" class="w-full py-4 font-black uppercase rounded-xl text-black text-[10px] bg-yellow-400 shadow-lg">Ajouter le chapitre</button>
            </form>
          </div>
        </div>

        <div class="lg:col-span-2">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {currentMangas.map((manga) => (
              <div class="bg-zinc-900/30 border border-zinc-800 p-4 rounded-2xl flex gap-4 group">
                <img src={manga.cover} class="w-16 h-20 object-cover rounded-lg" alt="" />
                <div class="flex-1 flex flex-col justify-between py-1">
                  <div>
                    <h3 class="font-bold text-sm truncate uppercase">{manga.title}</h3>
                    <p class="text-[9px] font-black text-yellow-400 uppercase">{manga.chapters?.length || 0} Chapitres</p>
                  </div>
                  <button onclick={`deleteManga('${manga.id}')`} class="text-[9px] font-bold uppercase text-red-500/50 hover:text-red-500 w-fit transition-colors">Supprimer</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </main>

  <script id="mangas-data-raw" type="application/json" is:inline>{JSON.stringify(currentMangas)}</script>

  <script is:inline>
    // AUTHENTICATION
    const ADMIN_PASS = "MOT_DE_PASSE"; // CHANGE-LE ICI
    function auth() {
      if (sessionStorage.getItem('rising_auth') === ADMIN_PASS) {
        document.getElementById('admin-gate').style.display = 'none';
        document.getElementById('admin-content').style.opacity = '1';
      } else {
        const p = prompt("Password:");
        if (p === ADMIN_PASS) { sessionStorage.setItem('rising_auth', ADMIN_PASS); auth(); }
        else { window.location.href = "/"; }
      }
    }
    auth();

    // TABS
    window.switchTab = (tab) => {
      const isManga = tab === 'new-manga';
      document.getElementById('form-new-manga').classList.toggle('hidden', !isManga);
      document.getElementById('form-new-chapter').classList.toggle('hidden', isManga);
      document.getElementById('btn-new-manga').className = isManga ? 'flex-1 py-2 text-[9px] font-black uppercase rounded-lg bg-yellow-400 text-black' : 'flex-1 py-2 text-[9px] font-black uppercase rounded-lg text-zinc-500';
      document.getElementById('btn-new-chapter').className = !isManga ? 'flex-1 py-2 text-[9px] font-black uppercase rounded-lg bg-yellow-400 text-black' : 'flex-1 py-2 text-[9px] font-black uppercase rounded-lg text-zinc-500';
    };

    // API CALLS
    const callAPI = async (data) => {
      try {
        const res = await fetch('/api/update-mangas', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        if (res.ok) window.location.reload();
        else alert("Erreur lors de l'envoi");
      } catch (e) { alert(e.message); }
    };

    // FORM HANDLERS
    document.getElementById('mangaForm').addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      callAPI({ action: "CREATE_MANGA", id: fd.get('id'), title: fd.get('title'), cover: fd.get('cover'), description: fd.get('description'), chapters: [] });
    });

    document.getElementById('chapterForm').addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      const pages = fd.get('pages').split(',').map(u => u.trim()).filter(u => u !== "");
      callAPI({ action: "ADD_CHAPTER", mangaId: fd.get('mangaId'), chapter: { number: fd.get('number'), title: `Chapitre ${fd.get('number')}`, date: fd.get('date'), pages: pages } });
    });

    window.deleteManga = (id) => { if (confirm(`Supprimer ${id} ?`)) callAPI({ action: "DELETE", id }); };

    document.getElementById('exportData').addEventListener('click', () => {
      const raw = document.getElementById('mangas-data-raw').textContent;
      const b = new Blob([JSON.stringify(JSON.parse(raw), null, 2)], { type: 'application/json' });
      const a = document.createElement('a'); a.href = URL.createObjectURL(b); a.download = 'rising_backup.json'; a.click();
    });
  </script>
</Layout>
