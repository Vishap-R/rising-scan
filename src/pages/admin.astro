---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admin Space - Rising Scan">
  <main id="adminContent" class="hidden min-h-screen bg-[#0b0b0b] text-white p-4 font-sans">
    
    <header class="flex justify-between items-center border-b-4 border-yellow-400 pb-4 mb-8">
      <h1 class="text-3xl font-black text-yellow-400 uppercase tracking-tighter italic">
        ⚡ Admin Space <span class="text-white text-sm font-normal not-italic">v2.1</span>
      </h1>
      <div class="space-x-2">
        <button id="exportBtn" class="bg-zinc-800 hover:bg-zinc-700 px-3 py-1 rounded text-[10px] font-bold border border-zinc-700 transition uppercase tracking-widest text-yellow-400">Export JSON</button>
        <button id="importBtn" class="bg-zinc-800 hover:bg-zinc-700 px-3 py-1 rounded text-[10px] font-bold border border-zinc-700 transition uppercase tracking-widest">Import JSON</button>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <section class="lg:col-span-1 space-y-6">
        <div class="bg-zinc-900 p-6 rounded-2xl border border-zinc-800 shadow-2xl">
          <h2 class="text-xl font-black mb-6 flex items-center gap-2 uppercase italic text-yellow-400">
            <span class="bg-yellow-400 text-black px-2 py-0.5 rounded-md not-italic font-black">1</span> Nouveau Manga
          </h2>
          
          <div class="space-y-4">
            <div>
              <label class="text-[10px] uppercase font-black text-zinc-500 ml-1">Titre Officiel</label>
              <input type="text" id="mangaTitle" placeholder="Ex: Solo Leveling" class="w-full bg-black border border-zinc-800 p-3 rounded-xl focus:border-yellow-400 outline-none text-white transition" />
            </div>

            <div>
              <label class="text-[10px] uppercase font-black text-zinc-500 ml-1">ID URL (Unique)</label>
              <input type="text" id="mangaId" placeholder="ex: solo-leveling" class="w-full bg-black border border-zinc-800 p-3 rounded-xl focus:border-yellow-400 outline-none text-zinc-400 transition" />
            </div>

            <div class="border-2 border-dashed border-zinc-800 p-6 rounded-2xl text-center hover:border-yellow-400 cursor-pointer transition bg-black group" id="dropZoneCover">
              <p class="text-zinc-500 text-xs font-bold uppercase group-hover:text-yellow-400" id="coverStatus">🖼️ Sélectionner la Cover</p>
              <input type="file" id="fileCover" accept="image/*" class="hidden" />
            </div>
            
            <div class="border-2 border-dashed border-zinc-800 p-6 rounded-2xl text-center hover:border-yellow-400 cursor-pointer transition bg-black group" id="dropZoneZip">
              <p class="text-zinc-500 text-xs font-bold uppercase group-hover:text-yellow-400" id="zipStatus">📁 Glisser le ZIP (Chap. 1)</p>
              <input type="file" id="fileZip" accept=".zip" class="hidden" />
            </div>

            <button id="addMangaBtn" class="w-full bg-yellow-400 hover:bg-yellow-300 text-black font-black py-4 rounded-xl uppercase transition transform active:scale-95 shadow-[0_0_20px_rgba(234,179,8,0.2)]">
              Ajouter à la file
            </button>
          </div>
        </div>
      </section>

      <section class="lg:col-span-2 space-y-6">
        <div class="flex justify-between items-center">
          <h2 class="text-2xl font-black italic uppercase tracking-tighter">File d'attente <span id="queueCount" class="text-yellow-400 ml-2">0</span></h2>
          <button id="publishBtn" class="bg-yellow-400 hover:bg-yellow-300 text-black font-black px-10 py-4 rounded-full shadow-xl transition-all flex items-center gap-2 uppercase italic disabled:opacity-50">
             🚀 Publier sur le Cloud
          </button>
        </div>
        
        <div id="mangaList" class="grid grid-cols-1 gap-4">
          </div>
      </section>
    </div>
  </main>
</Layout>

<script>
  import JSZip from 'jszip';

  // --- SÉCURITÉ ACCÈS ---
  const pass = prompt("Accès Admin - Mot de passe :");
  if (pass === "risingtest") { // ⚠️ Remplace par ton mot de passe
      document.getElementById('adminContent').classList.remove('hidden');
  } else {
      alert("Accès refusé.");
      window.location.href = "/";
  }

  // --- VARIABLES ---
  let db = JSON.parse(localStorage.getItem('rising_scan_db')) || [];
  let currentZipPages = [];
  let currentCoverBlob = null;
  const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

  // --- GESTION COVER ---
  document.getElementById('dropZoneCover').onclick = () => document.getElementById('fileCover').click();
  document.getElementById('fileCover').onchange = (e) => {
    currentCoverBlob = e.target.files[0];
    if(currentCoverBlob) document.getElementById('coverStatus').innerText = "✅ " + currentCoverBlob.name;
  };

  // --- GESTION ZIP ---
  document.getElementById('dropZoneZip').onclick = () => document.getElementById('fileZip').click();
  document.getElementById('fileZip').onchange = async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    
    document.getElementById('zipStatus').innerText = "⏳ Analyse du ZIP...";
    const zip = new JSZip();
    const contents = await zip.loadAsync(file);
    currentZipPages = [];

    const files = Object.keys(contents.files)
        .filter(f => f.match(/\.(jpg|jpeg|png|webp)$/i))
        .sort((a, b) => a.localeCompare(b, undefined, {numeric: true}));
    
    for (let filename of files) {
        const blob = await contents.files[filename].async("blob");
        currentZipPages.push({ name: filename, blob: blob });
    }
    document.getElementById('zipStatus').innerText = `✅ ${currentZipPages.length} Pages chargées`;
  };

  // --- CLOUDINARY UPLOAD ---
  async function uploadToCloudinary(fileBlob, folderPath) {
    const formData = new FormData();
    formData.append('file', fileBlob);
    formData.append('upload_preset', 'ml_default');
    formData.append('folder', folderPath);

    const res = await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/image/upload`, {
      method: 'POST',
      body: formData
    });
    if(!res.ok) throw new Error("Échec upload Cloudinary");
    return await res.json();
  }

  // --- AJOUT À LA FILE ---
  document.getElementById('addMangaBtn').onclick = () => {
    const title = document.getElementById('mangaTitle').value;
    const id = document.getElementById('mangaId').value;
    
    if(!title || !id || currentZipPages.length === 0 || !currentCoverBlob) {
        return alert("Erreur : Titre, ID, Cover et ZIP sont obligatoires !");
    }

    db.push({
      id, title, status: "Ongoing",
      coverBlob: currentCoverBlob, // Stocké temporairement
      chapters: [{ 
        number: "1", 
        title: "Chapitre 1", 
        date: new Date().toLocaleDateString(), 
        pages: currentZipPages 
      }]
    });

    save();
    // Reset formulaire
    currentZipPages = [];
    currentCoverBlob = null;
    document.getElementById('mangaTitle').value = "";
    document.getElementById('mangaId').value = "";
    document.getElementById('coverStatus').innerText = "🖼️ Sélectionner la Cover";
    document.getElementById('zipStatus').innerText = "📁 Glisser le ZIP (Chap. 1)";
  };

  // --- PUBLICATION FINALE ---
  document.getElementById('publishBtn').onclick = async () => {
    const btn = document.getElementById('publishBtn');
    btn.innerText = "⏳ ENVOI EN COURS...";
    btn.disabled = true;

    try {
      for (let manga of db) {
        // 1. Upload de la Cover
        if (manga.coverBlob) {
            const cData = await uploadToCloudinary(manga.coverBlob, `rising-scan/${manga.id}/assets`);
            manga.cover = cData.secure_url;
            delete manga.coverBlob;
        }

        // 2. Upload des Pages
        const finalPages = [];
        for (let i = 0; i < manga.chapters[0].pages.length; i++) {
            const p = manga.chapters[0].pages[i];
            btn.innerText = `⏳ PAGE ${i+1}/${manga.chapters[0].pages.length}...`;
            const pData = await uploadToCloudinary(p.blob, `rising-scan/${manga.id}/ch1`);
            finalPages.push(pData.secure_url);
        }
        manga.chapters[0].pages = finalPages;

        // 3. Envoi GitHub
        const res = await fetch('/api/update-mangas', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'json', mangaData: manga })
        });
        if (!res.ok) throw new Error("Erreur GitHub API");
      }
      
      alert("🔥 PUBLICATION RÉUSSIE !");
      db = [];
      save();
    } catch (err) {
      alert("❌ ERREUR : " + err.message);
      console.error(err);
    } finally {
      btn.innerText = "🚀 TOUT PUBLIER";
      btn.disabled = false;
    }
  };

  // --- FONCTIONS UTILES ---
  function save() {
    localStorage.setItem('rising_scan_db', JSON.stringify(db));
    render();
  }

  function render() {
    document.getElementById('queueCount').innerText = db.length;
    const list = document.getElementById('mangaList');
    list.innerHTML = db.map((m, i) => `
      <div class="bg-zinc-900 border border-zinc-800 p-4 flex justify-between items-center rounded-2xl shadow-lg">
        <div class="flex items-center gap-4">
            <div class="w-12 h-16 bg-black rounded-lg border border-zinc-800 overflow-hidden">
                <p class="text-[8px] text-center mt-4 text-zinc-600">READY</p>
            </div>
            <div>
              <h3 class="font-black text-yellow-400 uppercase italic">${m.title}</h3>
              <p class="text-[10px] text-zinc-500 font-bold uppercase">${m.chapters[0].pages.length} PAGES À UPLOADER</p>
            </div>
        </div>
        <button onclick="removeManga(${i})" class="text-zinc-600 hover:text-red-500 transition font-bold text-xs uppercase">Retirer</button>
      </div>
    `).join('');
  }

  window.removeManga = (i) => {
    db.splice(i, 1);
    save();
  };

  // Export/Import
  document.getElementById('exportBtn').onclick = () => {
    const blob = new Blob([JSON.stringify(db)], {type:'application/json'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'rising_backup.json';
    a.click();
  };

  document.getElementById('importBtn').onclick = () => {
    const input = document.createElement('input');
    input.type = 'file';
    input.onchange = e => {
      const reader = new FileReader();
      reader.onload = () => { db = JSON.parse(reader.result); save(); };
      reader.readAsText(e.target.files[0]);
    };
    input.click();
  };

  render();
</script>
