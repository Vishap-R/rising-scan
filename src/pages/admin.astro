---
import Layout from '../layouts/Layout.astro';
import mangasData from '../data/mangas.json';

const rawData = mangasData?.default || mangasData;
const currentMangas = Array.isArray(rawData) ? rawData : (rawData ? [rawData] : []);
const yellow = "#F9D71C";
---

<Layout title="Admin Space - Rising Scan">
  <div id="admin-gate" class="fixed inset-0 bg-black z-[100] flex items-center justify-center">
    <div class="text-center">
      <h2 class="text-xl font-black uppercase italic text-white">Accès Restreint</h2>
    </div>
  </div>

  <main id="admin-content" class="min-h-screen bg-[#0b0b0b] text-white p-6 md:p-12 opacity-0 transition-opacity">
    <div class="max-w-6xl mx-auto">
      
      <div class="flex justify-between items-center mb-12 border-b border-zinc-800 pb-6">
        <h1 class="text-3xl font-black uppercase italic">Admin <span style={`color: ${yellow}`}>Space</span></h1>
        <button id="exportData" class="text-[10px] font-bold uppercase bg-zinc-900 px-4 py-2 rounded-lg border border-zinc-800">Backup JSON</button>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        <div class="lg:col-span-1 space-y-6">
          
          <div class="flex bg-zinc-900 p-1 rounded-xl border border-zinc-800">
            <button onclick="switchTab('manga')" id="btn-manga" class="flex-1 py-2 text-[9px] font-black uppercase rounded-lg bg-yellow-400 text-black">Nouveau Manga</button>
            <button onclick="switchTab('zip')" id="btn-zip" class="flex-1 py-2 text-[9px] font-black uppercase rounded-lg text-zinc-500">Upload ZIP</button>
          </div>

          <div id="pane-manga" class="bg-zinc-900/50 p-6 rounded-2xl border border-zinc-800 shadow-xl">
            <form id="mangaForm" class="space-y-4">
              <input type="text" name="id" placeholder="ID (ex: TFSOE)" required class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm focus:border-yellow-400 outline-none" />
              <input type="text" name="title" placeholder="Titre" required class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm focus:border-yellow-400 outline-none" />
              <input type="url" name="cover" placeholder="Lien Cover" required class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm focus:border-yellow-400 outline-none" />
              <button type="submit" class="w-full py-4 font-black uppercase rounded-xl text-black text-[10px] bg-yellow-400">Créer l'œuvre</button>
            </form>
          </div>

          <div id="pane-zip" class="hidden space-y-4">
            <div id="drop-zone" class="border-2 border-dashed border-zinc-800 rounded-2xl p-8 text-center bg-zinc-900/30 hover:border-yellow-400 cursor-pointer transition-all">
              <input type="file" id="zip-input" accept=".zip" class="hidden" />
              <p class="text-[10px] font-bold uppercase text-zinc-500">Glisser le .ZIP ici</p>
            </div>
            
            <div id="zip-config" class="bg-zinc-900/50 p-6 rounded-2xl border border-zinc-800 hidden space-y-4">
              <select id="mangaTarget" class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm outline-none">
                {currentMangas.map(m => <option value={m.id}>{m.title}</option>)}
              </select>
              <input type="number" id="chNum" placeholder="N° Chapitre" class="w-full bg-black border border-zinc-800 rounded-xl p-3 text-sm outline-none" />
              
              <div id="progress-container" class="hidden space-y-2">
                <div class="flex justify-between text-[9px] font-black text-yellow-400 uppercase">
                  <span id="prog-text">Prêt</span>
                  <span id="prog-perc">0%</span>
                </div>
                <div class="h-1 bg-zinc-800 rounded-full overflow-hidden">
                  <div id="prog-bar" class="h-full bg-yellow-400 w-0 transition-all"></div>
                </div>
              </div>

              <button id="uploadZipBtn" class="w-full py-4 bg-yellow-400 text-black font-black uppercase text-[10px] rounded-xl shadow-lg">Lancer l'Upload</button>
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-4">
          {currentMangas.map((manga) => (
            <div class="bg-zinc-900/30 border border-zinc-800 p-4 rounded-2xl flex gap-4 group hover:border-zinc-500 transition-all">
              <img src={manga.cover} class="w-16 h-20 object-cover rounded-lg shadow-lg" alt="" />
              <div class="flex-1 flex flex-col justify-between py-1">
                <div>
                  <h3 class="font-bold text-sm truncate uppercase tracking-tight">{manga.title}</h3>
                  <p class="text-[9px] font-black uppercase text-yellow-400">{manga.chapters?.length || 0} Chapitres</p>
                </div>
                <button onclick={`deleteManga('${manga.id}')`} class="text-[9px] font-bold uppercase text-red-500/50 hover:text-red-500 transition-colors w-fit">Supprimer</button>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </main>

  <script id="raw-data" type="application/json" is:inline>{JSON.stringify(currentMangas)}</script>

  <script>
    import JSZip from 'jszip';

    // 1. SÉCURITÉ
    const PASS = "TON_MOT_DE_PASSE";
    if (sessionStorage.getItem('rs_auth') !== PASS) {
      const p = prompt("Password:");
      if (p === PASS) { 
        sessionStorage.setItem('rs_auth', PASS);
        initAdmin();
      } else { window.location.href = "/"; }
    } else { initAdmin(); }

    function initAdmin() {
      document.getElementById('admin-gate')!.style.display = 'none';
      document.getElementById('admin-content')!.classList.replace('opacity-0', 'opacity-100');
    }

    // 2. TABS
    window.switchTab = (tab: string) => {
      const isManga = tab === 'manga';
      document.getElementById('pane-manga')!.classList.toggle('hidden', !isManga);
      document.getElementById('pane-zip')!.classList.toggle('hidden', isManga);
      document.getElementById('btn-manga')!.className = isManga ? 'flex-1 py-2 text-[9px] font-black uppercase rounded-lg bg-yellow-400 text-black' : 'flex-1 py-2 text-[9px] font-black uppercase rounded-lg text-zinc-500';
      document.getElementById('btn-zip')!.className = !isManga ? 'flex-1 py-2 text-[9px] font-black uppercase rounded-lg bg-yellow-400 text-black' : 'flex-1 py-2 text-[9px] font-black uppercase rounded-lg text-zinc-500';
    };

    // 3. ZIP HANDLER
    const zipInput = document.getElementById('zip-input') as HTMLInputElement;
    const dropZone = document.getElementById('drop-zone');
    let zipFile: File | null = null;

    dropZone?.addEventListener('click', () => zipInput.click());
    zipInput.addEventListener('change', (e: any) => handleZip(e.target.files[0]));
    
    function handleZip(file: File) {
      if (file?.name.endsWith('.zip')) {
        zipFile = file;
        document.getElementById('zip-config')!.classList.remove('hidden');
        dropZone!.querySelector('p')!.innerText = `Fichier : ${file.name}`;
      }
    }

    document.getElementById('uploadZipBtn')?.addEventListener('click', async () => {
      if (!zipFile) return;
      const mangaId = (document.getElementById('mangaTarget') as HTMLSelectElement).value;
      const chNum = (document.getElementById('chNum') as HTMLInputElement).value;
      if(!chNum) return alert("Numéro manquant");

      const progCont = document.getElementById('progress-container');
      const progBar = document.getElementById('prog-bar');
      const progText = document.getElementById('prog-text');
      const progPerc = document.getElementById('prog-perc');

      progCont?.classList.remove('hidden');

      try {
        const zip = new JSZip();
        const content = await zip.loadAsync(zipFile);
        const images = Object.keys(content.files).filter(f => f.match(/\.(jpg|jpeg|png|webp)$/i)).sort();
        
        const urls: string[] = [];
        const CLOUD_NAME = "dw6lou8mv";
        const PRESET = "ml_default";

        for (let i = 0; i < images.length; i++) {
          const blob = await content.files[images[i]].async("blob");
          const fd = new FormData();
          fd.append('file', blob);
          fd.append('upload_preset', PRESET);

          const res = await fetch(`https://api.cloudinary.com/v1_1/${CLOUD_NAME}/image/upload`, { method: 'POST', body: fd });
          const json = await res.json();
          urls.push(json.secure_url);

          const p = Math.round(((i + 1) / images.length) * 100);
          progBar!.style.width = `${p}%`;
          progPerc!.innerText = `${p}%`;
          progText!.innerText = `Upload ${i+1}/${images.length}`;
        }

        // Envoi final
        const final = await fetch('/api/update-mangas', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: "ADD_CHAPTER", mangaId, chapter: { number: chNum, date: new Date().toLocaleDateString(), pages: urls } })
        });
        if (final.ok) window.location.reload();

      } catch (e) { alert("Erreur upload"); }
    });

    // 4. DELETE & MANGA CREATE
    (window as any).deleteManga = async (id: string) => {
      if(confirm(`Supprimer ${id} ?`)) {
        await fetch('/api/update-mangas', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: "DELETE", id }) });
        window.location.reload();
      }
    };

    document.getElementById('mangaForm')?.addEventListener('submit', async (e: any) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      await fetch('/api/update-mangas', { 
        method: 'POST', 
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify({ action: "CREATE_MANGA", id: fd.get('id'), title: fd.get('title'), cover: fd.get('cover'), chapters: [] }) 
      });
      window.location.reload();
    });
  </script>
</Layout>
