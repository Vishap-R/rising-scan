---
import Layout from '../layouts/Layout.astro';
import mangasData from '../data/mangas.json';

// Récupération des mangas existants pour le Dashboard
const rawData = mangasData?.default || mangasData;
const currentMangas = Array.isArray(rawData) ? rawData : (rawData ? [rawData] : []);

const yellow = "#F9D71C";
---

<Layout title="Admin Space - Rising Scan">
  <main class="min-h-screen bg-[#0b0b0b] text-white p-4 md:p-10">
    
    <div class="max-w-6xl mx-auto">
      <div class="flex justify-between items-center mb-12 border-b border-zinc-800 pb-6">
        <div>
          <h1 class="text-3xl font-black uppercase italic tracking-tighter">
            Admin <span style={`color: ${yellow}`}>Space</span>
          </h1>
          <p class="text-zinc-500 text-xs font-bold uppercase tracking-widest mt-1">Gestion du catalogue</p>
        </div>
        <button id="exportData" class="px-4 py-2 bg-zinc-900 border border-zinc-800 rounded-lg text-[10px] font-bold uppercase hover:bg-zinc-800 transition-all">
          📥 Export Backup (JSON)
        </button>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        <div class="lg:col-span-1 space-y-6">
          <div class="bg-zinc-900/50 p-6 rounded-2xl border border-zinc-800 shadow-xl">
            <h2 class="text-sm font-black uppercase mb-6 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style={`background-color: ${yellow}`}></span>
              Ajouter une œuvre
            </h2>
            
            <form id="mangaForm" class="space-y-4">
              <div>
                <label class="block text-[10px] uppercase font-bold text-zinc-500 mb-1">ID Unique (ex: TFSOE)</label>
                <input type="text" name="id" required class="w-full bg-black border border-zinc-800 rounded-lg p-3 text-sm focus:border-yellow-400 outline-none transition-all" />
              </div>
              <div>
                <label class="block text-[10px] uppercase font-bold text-zinc-500 mb-1">Titre du Manga</label>
                <input type="text" name="title" required class="w-full bg-black border border-zinc-800 rounded-lg p-3 text-sm focus:border-yellow-400 outline-none transition-all" />
              </div>
              <div>
                <label class="block text-[10px] uppercase font-bold text-zinc-500 mb-1">URL Cover (Cloudinary)</label>
                <input type="url" name="cover" required class="w-full bg-black border border-zinc-800 rounded-lg p-3 text-sm focus:border-yellow-400 outline-none transition-all" />
              </div>
              <div>
                <label class="block text-[10px] uppercase font-bold text-zinc-500 mb-1">Synopsis</label>
                <textarea name="description" rows="4" class="w-full bg-black border border-zinc-800 rounded-lg p-3 text-sm focus:border-yellow-400 outline-none transition-all resize-none"></textarea>
              </div>

              <button type="submit" class="w-full py-4 font-black uppercase tracking-widest rounded-xl text-black text-xs transition-transform active:scale-95 shadow-lg" style={`background-color: ${yellow}`}>
                Publier l'œuvre
              </button>
            </form>
          </div>
        </div>

        <div class="lg:col-span-2">
          <h2 class="text-sm font-black uppercase mb-6 flex items-center gap-2 text-zinc-400">
            Catalogue Actuel ({currentMangas.length})
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {currentMangas.map((manga) => (
              <div class="bg-zinc-900/30 border border-zinc-800 p-4 rounded-xl flex gap-4 group hover:border-zinc-600 transition-all">
                <img src={manga.cover} class="w-16 h-20 object-cover rounded-lg shadow-lg" alt="" />
                <div class="flex-1 flex flex-col justify-between">
                  <div>
                    <h3 class="font-bold text-sm truncate">{manga.title}</h3>
                    <p class="text-[10px] text-zinc-500 uppercase font-black">{manga.chapters?.length || 0} Chapitres</p>
                  </div>
                  <div class="flex gap-2">
                    <button onclick={`deleteManga('${manga.id}')`} class="text-[9px] font-bold uppercase text-red-500 hover:text-red-400 transition-colors">
                      Supprimer
                    </button>
                  </div>
                </div>
              </div>
            ))}
            
            {currentMangas.length === 0 && (
              <div class="col-span-full py-20 border-2 border-dashed border-zinc-800 rounded-2xl text-center">
                <p class="text-zinc-600 text-xs font-bold uppercase tracking-widest">Aucun manga dans le catalogue</p>
              </div>
            )}
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  // 1. GESTION DE L'AJOUT
  const form = document.getElementById('mangaForm');
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = {
      id: formData.get('id'),
      title: formData.get('title'),
      cover: formData.get('cover'),
      description: formData.get('description'),
      status: "En cours",
      chapters: [] // Initialise avec 0 chapitres
    };

    if(!confirm(`Confirmer la publication de : ${data.title} ?`)) return;

    try {
      const response = await fetch('/api/update-mangas', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      if (response.ok) {
        alert("🎉 Manga ajouté avec succès ! Redémarrage du build...");
        window.location.reload();
      }
    } catch (err) {
      alert("Erreur : " + err.message);
    }
  });

  // 2. GESTION DE LA SUPPRESSION
  window.deleteManga = async (id) => {
    if (!confirm(`⚠️ Êtes-vous sûr de vouloir supprimer définitivement ${id} ?`)) return;

    try {
      const response = await fetch('/api/update-mangas', {
        method: 'POST', // On utilise POST avec une action spécifique
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: "DELETE", id: id })
      });
      if (response.ok) {
        alert("🗑️ Manga supprimé !");
        window.location.reload();
      }
    } catch (err) {
      alert("Erreur lors de la suppression");
    }
  };

  // 3. EXPORT DES DONNÉES (Sécurité LocalStorage)
  document.getElementById('exportData').addEventListener('click', () => {
    // Note: Dans un vrai cas, on ferait un fetch du JSON actuel
    // Ici, on propose de télécharger les données chargées
    const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(window.__MANGAS_DATA__ || [], null, 2));
    const downloadAnchorNode = document.createElement('a');
    downloadAnchorNode.setAttribute("href", dataStr);
    downloadAnchorNode.setAttribute("download", "rising_scan_backup.json");
    document.body.appendChild(downloadAnchorNode);
    downloadAnchorNode.click();
    downloadAnchorNode.remove();
  });
</script>
