---
import Layout from '../../layouts/Layout.astro';
import mangasData from '../../data/mangas.json';

export async function getStaticPaths() {
  const rawData = mangasData?.default || mangasData;
  if (!rawData) return [];
  const mangasArray = Array.isArray(rawData) ? rawData : [rawData];
  const validMangas = mangasArray.filter(m => m && typeof m === 'object' && m.id);

  return validMangas.map((manga) => ({
    params: { id: manga.id.toString() },
    props: { manga },
  }));
}

const { manga } = Astro.props;
const yellow = "#F9D71C";

// Tri des chapitres par numéro (du plus récent au plus ancien)
const sortedChapters = [...manga.chapters].sort((a, b) => b.number - a.number);
const firstChapter = manga.chapters[0];
const lastChapter = sortedChapters[0];
---

<Layout title={`${manga.title} - Rising Scan`}>
  <main class="min-h-screen bg-[#0b0b0b] text-white">
    
    <div class="relative h-[400px] w-full overflow-hidden">
      <div 
        class="absolute inset-0 bg-cover bg-center blur-3xl opacity-30 scale-110" 
        style={`background-image: url(${manga.cover})`}
      ></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#0b0b0b] via-[#0b0b0b]/60 to-transparent"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 -mt-64 relative z-10">
      <div class="flex flex-col md:flex-row gap-10">
        
        <div class="w-full md:w-72 flex-shrink-0">
          <div class="rounded-2xl overflow-hidden border-2 border-zinc-800 shadow-2xl bg-zinc-900 aspect-[3/4]">
            <img src={manga.cover} alt={manga.title} class="w-full h-full object-cover" loading="lazy" />
          </div>
          
          <div class="mt-6 space-y-4">
            <a href={`/lecture/${manga.id}/${firstChapter.number}`} class="flex items-center justify-center w-full py-4 bg-blue-600 hover:bg-blue-700 rounded-xl font-bold transition-all gap-2 text-sm">
               <span>📖</span> Commencer la lecture
            </a>
            <button class="w-full py-4 bg-zinc-900 border border-zinc-800 hover:border-zinc-600 rounded-xl font-bold transition-all text-sm">
               + Ajouter aux favoris
            </button>
            
            <div class="p-4 bg-zinc-900/50 rounded-xl border border-zinc-800/50 space-y-3 text-xs">
              <div class="flex justify-between"><span class="text-zinc-500">Statut</span><span class="text-green-400 font-bold uppercase">{manga.status || 'En cours'}</span></div>
              <div class="flex justify-between"><span class="text-zinc-500">Type</span><span class="text-purple-400 font-bold uppercase">Manhwa</span></div>
            </div>
          </div>
        </div>

        <div class="flex-1">
          <h1 class="text-4xl md:text-5xl font-black uppercase italic tracking-tighter mb-2">
            {manga.title}
          </h1>
          <p class="text-zinc-500 text-sm mb-8 font-medium italic">Nom original : {manga.title_jp || 'N/A'}</p>

          <section class="bg-zinc-900/40 border border-zinc-800 p-6 rounded-2xl mb-10">
            <h3 class="text-sm font-bold uppercase tracking-widest mb-3 flex items-center gap-2">
               <span style={`color: ${yellow}`}>⚡</span> Synopsis
            </h3>
            <p class="text-zinc-400 text-sm leading-relaxed italic">
              {manga.description || "Aucune description disponible pour le moment. Plongez dans cette aventure épique sur Rising Scan !"}
            </p>
          </section>

          <section>
            <div class="flex justify-between items-center mb-6">
              <h3 class="text-xl font-black uppercase italic italic flex items-center gap-3">
                <span class="w-8 h-1 rounded-full" style={`background-color: ${yellow}`}></span>
                Chapitres
              </h3>
              <span class="text-[10px] bg-zinc-800 px-3 py-1 rounded-full text-zinc-400 font-bold uppercase">
                {manga.chapters.length} épisodes
              </span>
            </div>

            <div class="grid gap-3">
              {sortedChapters.map((ch) => (
                <a 
                  href={`/lecture/${manga.id}/${ch.number}`}
                  class="group flex items-center justify-between p-4 bg-zinc-900/40 hover:bg-zinc-800 border border-zinc-800 hover:border-yellow-400/50 rounded-xl transition-all"
                >
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-lg bg-zinc-800 flex items-center justify-center font-black text-zinc-500 group-hover:text-yellow-400 transition-colors">
                      {ch.number}
                    </div>
                    <div>
                      <h4 class="font-bold text-sm group-hover:text-white">Chapitre {ch.number}</h4>
                      <p class="text-[10px] text-zinc-500 uppercase font-bold">{ch.date || 'Récemment'}</p>
                    </div>
                  </div>
                  <span class="text-zinc-700 group-hover:text-yellow-400 transition-colors">▶</span>
                </a>
              ))}
            </div>
          </section>
        </div>

      </div>
    </div>

    <footer class="mt-20 py-10 border-t border-zinc-900 text-center opacity-20">
      <p class="text-[9px] uppercase tracking-[0.5em]">Rising Scan — {manga.id}</p>
    </footer>
  </main>
</Layout>
