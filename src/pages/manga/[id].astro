---
import Layout from '../../layouts/Layout.astro';
import mangasData from '../../data/mangas.json';

// 1. Génération des routes statiques
export async function getStaticPaths() {
  // Gestion de l'import Astro (.default)
  const rawData = mangasData?.default || mangasData;
  
  if (!rawData) return [];

  // On s'assure d'avoir un tableau
  const mangasArray = Array.isArray(rawData) ? rawData : [rawData];
  
  // FILTRE DE SÉCURITÉ : On ignore tout ce qui n'est pas un manga valide avec des chapitres
  const validMangas = mangasArray.filter(m => 
    m && typeof m === 'object' && m.id && m.chapters && m.chapters.length > 0
  );

  return validMangas.map((manga) => ({
    params: { id: manga.id.toString() },
    props: { manga },
  }));
}

// 2. Récupération des données du manga pour la page
const { manga } = Astro.props;

// 3. Définition des variables (Utilisées dans le HTML ci-dessous)
const currentChapter = manga.chapters[0];
const yellow = "#F9D71C";

// Logique pour trouver le chapitre suivant (si il existe)
const nextChapter = manga.chapters.find(ch => 
  parseInt(ch.number) === parseInt(currentChapter.number) + 1
);
---

<Layout title={`${manga.title} - Chapitre ${currentChapter.number}`}>
  
  <div class="bg-[#0b0b0b]/95 border-b border-zinc-800 p-3 sticky top-0 z-40 backdrop-blur-sm">
    <div class="max-w-3xl mx-auto flex justify-between items-center px-4">
      <div class="flex flex-col">
        <span class="text-[10px] uppercase font-bold tracking-widest" style={`color: ${yellow}`}>Lecture en cours</span>
        <h2 class="font-bold text-sm truncate w-40 sm:w-auto text-white uppercase italic">
            {manga.title} <span class="opacity-50 ml-1">#Ch.{currentChapter.number}</span>
        </h2>
      </div>
      
      <div class="flex gap-3">
        <select class="bg-zinc-900 border border-zinc-700 text-white text-[10px] font-bold uppercase p-2 rounded outline-none focus:border-[#F9D71C] cursor-pointer">
          {manga.chapters.map(ch => (
            <option selected={ch.number === currentChapter.number}>
              Chapitre {ch.number}
            </option>
          ))}
        </select>
      </div>
    </div>
  </div>

  <main class="max-w-4xl mx-auto flex flex-col items-center">
    
    <div class="w-full flex flex-col bg-black shadow-2xl">
      {currentChapter.pages.map((page, index) => (
        <div class="relative w-full border-b border-zinc-900/10 group">
          <img 
            src={page} 
            loading="lazy" 
            decoding="async"
            alt={`Page ${index + 1}`}
            class="w-full h-auto block"
            onerror="this.src='https://via.placeholder.com/800x1200?text=Image+Indisponible'"
          />
          <div class="absolute bottom-4 right-4 bg-black/60 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-mono text-zinc-300 opacity-0 group-hover:opacity-100 transition-opacity border border-zinc-800">
            {index + 1} / {currentChapter.pages.length}
          </div>
        </div>
      ))}
    </div>

    <div class="w-full py-24 px-4 text-center space-y-8 bg-gradient-to-b from-black to-[#0b0b0b] text-white">
      <div class="inline-block p-5 rounded-full bg-zinc-900 mb-4 border border-zinc-800 shadow-[0_0_20px_rgba(249,215,28,0.2)]" style={`color: ${yellow}`}>
        <span class="text-2xl">⚡</span>
      </div>
      
      <h3 class="text-2xl font-black italic uppercase tracking-tighter">
        Fin du Chapitre {currentChapter.number}
      </h3>
      
      <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
        <a href="/" class="group flex items-center gap-2 px-10 py-4 bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 rounded-xl font-bold text-xs uppercase transition-all tracking-widest text-zinc-400 hover:text-white">
          <span>←</span> Catalogue
        </a>
        
        {nextChapter ? (
          <a href={`/manga/${manga.id}/chapitre-${nextChapter.number}`} 
             class="px-12 py-4 font-black text-xs uppercase rounded-xl transition-all tracking-widest text-black shadow-xl hover:scale-105 active:scale-95" 
             style={`background-color: ${yellow}`}>
            Chapitre Suivant
          </a>
        ) : (
          <button disabled class="px-12 py-4 font-bold text-xs uppercase rounded-xl bg-zinc-900 text-zinc-600 border border-zinc-800 cursor-not-allowed tracking-widest opacity-50">
            Dernier Chapitre
          </button>
        )}
      </div>
    </div>
  </main>

  <footer class="py-10 text-center border-t border-zinc-900 opacity-30">
    <p class="text-[9px] uppercase tracking-[0.6em] text-white">Rising Scan Reader</p>
  </footer>

</Layout>

<style>
  /* Protection simple contre le clic droit/drag */
  img {
    -webkit-user-select: none;
    -ms-user-select: none;
    user-select: none;
    pointer-events: none;
    -webkit-touch-callout: none;
  }
  
  /* Animation d'entrée */
  main {
    animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
