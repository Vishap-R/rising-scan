---
import Layout from '../../layouts/Layout.astro';
import mangasData from '../../data/mangas.json';

// Génération des pages statiques pour Vercel
export async function getStaticPaths() {
  // Extraction sécurisée (gestion du .default d'Astro)
  const rawData = mangasData?.default || mangasData;

  // SÉCURITÉ CRITIQUE : Si le JSON est vide ou invalide, on ne génère rien au lieu de planter
  if (!rawData || (Array.isArray(rawData) && rawData.length === 0)) {
    return [];
  }

  // Force le format tableau si c'est un objet unique
  const mangas = Array.isArray(rawData) ? rawData : [rawData];
  
  return mangas.map((manga) => ({
    params: { id: manga.id.toString() },
    props: { manga },
  }));
}

const { manga } = Astro.props;

// Sécurité : Si le manga n'a pas de chapitres
if (!manga || !manga.chapters || manga.chapters.length === 0) {
  return Astro.redirect('/404');
}

const yellow = "#F9D71C";
// On récupère le premier chapitre (ou tu peux adapter pour gérer plusieurs chapitres via l'URL)
const currentChapter = manga.chapters[0];

// Logique pour le bouton "Chapitre Suivant"
const nextChapter = manga.chapters.find(ch => parseInt(ch.number) === parseInt(currentChapter.number) + 1);
---

<Layout title={`${manga.title} - Chapitre ${currentChapter.number}`}>
  
  <div class="bg-[#0b0b0b]/95 border-b border-zinc-800 p-3 sticky top-0 z-40 backdrop-blur-sm">
    <div class="max-w-3xl mx-auto flex justify-between items-center px-4">
      <div class="flex flex-col">
        <span class="text-[10px] uppercase font-bold tracking-widest" style={`color: ${yellow}`}>Lecture en cours</span>
        <h2 class="font-bold text-sm truncate w-40 sm:w-auto text-white uppercase italic">
            {manga.title} <span class="opacity-50 ml-1">#Ch.{currentChapter.number}</span>
        </h2>
      </div>
      
      <div class="flex gap-3">
        <select class="bg-zinc-900 border border-zinc-700 text-white text-[10px] font-bold uppercase p-2 rounded outline-none focus:border-[#F9D71C] cursor-pointer">
          {manga.chapters.map(ch => (
            <option selected={ch.number === currentChapter.number}>
              Chapitre {ch.number}
            </option>
          ))}
        </select>
      </div>
    </div>
  </div>

  <main class="max-w-4xl mx-auto flex flex-col items-center">
    <div class="w-full flex flex-col bg-black">
      {currentChapter.pages.map((page, index) => (
        <div class="relative w-full border-b border-zinc-900/50 group">
          <img 
            src={page} 
            loading="lazy" 
            alt={`Page ${index + 1}`}
            class="w-full h-auto block"
            onerror="this.src='https://via.placeholder.com/800x1200?text=Image+Non+Trouvée'"
          />
          <div class="absolute bottom-4 right-4 bg-black/50 backdrop-blur-md px-2 py-1 rounded text-[10px] font-mono text-zinc-300 opacity-0 group-hover:opacity-100 transition-opacity">
            {index + 1} / {currentChapter.pages.length}
          </div>
        </div>
      ))}
    </div>

    <div class="w-full py-20 px-4 text-center space-y-8 bg-gradient-to-b from-black to-[#0b0b0b] text-white">
      <div class="inline-block p-4 rounded-full bg-zinc-900 mb-4 shadow-[0_0_15px_rgba(249,215,28,0.3)]" style={`color: ${yellow}`}>
        ⚡
      </div>
      <h3 class="text-xl font-black italic uppercase tracking-tighter">Fin du Chapitre {currentChapter.number}</h3>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/" class="px-10 py-4 bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 rounded-xl font-bold text-xs uppercase transition-all tracking-widest">
          Catalogue
        </a>
        
        {nextChapter ? (
          <a href={`/manga/${manga.id}/chapitre-${nextChapter.number}`} 
             class="px-10 py-4 font-bold text-xs uppercase rounded-xl transition-all tracking-widest text-black shadow-lg" 
             style={`background-color: ${yellow}`}>
            Chapitre Suivant
          </a>
        ) : (
          <button disabled class="px-10 py-4 font-bold text-xs uppercase rounded-xl bg-zinc-800 text-zinc-500 cursor-not-allowed tracking-widest opacity-50">
            Dernier Chapitre
          </button>
        )}
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Protection basique des images */
  img {
    -webkit-user-select: none;
    -moz-user-select: none;
    user-select: none;
    pointer-events: none;
  }
</style>
